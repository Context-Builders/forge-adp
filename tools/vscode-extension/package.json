{
  "name": "forge-adp",
  "displayName": "Forge ADP",
  "description": "Submit tasks to Forge agents, track progress, and approve checkpoints directly from VS Code.",
  "icon": "images/forge-adp.png",
  "version": "0.1.2",
  "license": "Apache-2.0",
  "publisher": "context-builders",
  "repository": {
    "type": "git",
    "url": "https://github.com/Context-Builders/forge-adp"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other", "AI"],
  "keywords": ["forge", "agents", "ai", "orchestration"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Forge ADP",
      "properties": {
        "forge.orchestratorUrl": {
          "type": "string",
          "default": "http://localhost:19080",
          "description": "Base URL of the Forge Orchestrator service."
        },
        "forge.registryUrl": {
          "type": "string",
          "default": "http://localhost:19081",
          "description": "Base URL of the Forge Registry service."
        },
        "forge.apiToken": {
          "type": "string",
          "default": "",
          "description": "Bearer token for Forge API authentication (leave blank for local dev).",
          "markdownDescription": "Bearer token for Forge API authentication. For production use [Secrets Storage](https://code.visualstudio.com/api/references/vscode-api#SecretStorage) is recommended over storing tokens here."
        },
        "forge.pollIntervalSeconds": {
          "type": "number",
          "default": 15,
          "minimum": 5,
          "description": "How often (in seconds) to refresh the task list in the sidebar."
        },
        "forge.seederPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the Forge seeder binary. Required to use the 'Seed project first' option in the Bootstrap tab (e.g. /Users/me/forge-adp/seeder)."
        },
        "forge.anthropicApiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API key used by the PM Plan chat to conduct project discovery interviews. Get one at https://console.anthropic.com."
        },
        "forge.plannerModel": {
          "type": "string",
          "default": "claude-opus-4-6",
          "description": "Claude model used for the PM Plan chat interview (e.g. claude-opus-4-6, claude-sonnet-4-6)."
        }
      }
    },
    "commands": [
      {
        "command": "forge.submitTask",
        "title": "Forge: Submit Task",
        "icon": "$(play)"
      },
      {
        "command": "forge.getTask",
        "title": "Forge: Get Task Status"
      },
      {
        "command": "forge.listTasks",
        "title": "Forge: List Tasks",
        "icon": "$(list-unordered)"
      },
      {
        "command": "forge.approveTask",
        "title": "Forge: Approve Task",
        "icon": "$(check)"
      },
      {
        "command": "forge.rejectTask",
        "title": "Forge: Reject Task",
        "icon": "$(x)"
      },
      {
        "command": "forge.refreshTasks",
        "title": "Forge: Refresh Task List",
        "icon": "$(refresh)"
      },
      {
        "command": "forge.openTaskInBrowser",
        "title": "Forge: Open Task in Browser",
        "icon": "$(link-external)"
      },
      {
        "command": "forge.checkHealth",
        "title": "Forge: Check Service Health"
      },
      {
        "command": "forge.bootstrapProject",
        "title": "Forge: Bootstrap Project",
        "icon": "$(rocket)"
      }
    ],
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "forge-adp",
          "title": "Forge ADP",
          "icon": "images/forge-adp.svg"
        }
      ]
    },
    "views": {
      "forge-adp": [
        {
          "type": "webview",
          "id": "forge.agentPanel",
          "name": "Agent Panel"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "forge.refreshTasks",
          "when": "view == forge.agentPanel",
          "group": "navigation@1"
        },
        {
          "command": "forge.checkHealth",
          "when": "view == forge.agentPanel",
          "group": "overflow@1"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsc -p ./tsconfig.json",
    "watch": "tsc -watch -p ./tsconfig.json",
    "lint": "eslint src --ext .ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {}
}
